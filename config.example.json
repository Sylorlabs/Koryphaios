{
  "$schema": "./koryphaios-schema.json",
  
  "providers": {
    "anthropic": {
      "name": "anthropic",
      "disabled": false,
      "baseUrl": "https://api.anthropic.com/v1"
    },
    "openai": {
      "name": "openai",
      "disabled": false,
      "baseUrl": "https://api.openai.com/v1"
    },
    "google": {
      "name": "google",
      "disabled": false
    },
    "groq": {
      "name": "groq",
      "disabled": false,
      "baseUrl": "https://api.groq.com/v1"
    },
    "xai": {
      "name": "xai",
      "disabled": false,
      "baseUrl": "https://api.x.ai/v1"
    }
  },
  
  "agents": {
    "manager": {
      "model": "claude-sonnet-4-5",
      "maxTokens": 8192,
      "reasoningLevel": "high"
    },
    "coder": {
      "model": "claude-sonnet-4-5",
      "maxTokens": 16384,
      "reasoningLevel": "medium"
    },
    "task": {
      "model": "o4-mini",
      "maxTokens": 8192
    }
  },

  "assignments": {
    "frontend": "openai:gpt-4.1",
    "backend": "google:gemini-2.5-pro",
    "critic": "anthropic:claude-sonnet-4-5",
    "general": "google:gemini-2.5-flash"
  },

  "fallbacks": {
    "gemini-2.5-pro": ["gpt-4.1", "claude-sonnet-4-5"],
    "gpt-4.1": ["gemini-2.5-flash"],
    "claude-sonnet-4-5": ["gpt-4.1"]
  },
  
  "server": {
    "port": 3001,
    "host": "localhost"
  },
  
  "dataDirectory": ".koryphaios",
  
  "contextPaths": [
    ".cursorrules",
    "CLAUDE.md",
    "AGENTS.md",
    ".opencode.json",
    "CONVENTIONS.md"
  ],
  
  "mcpServers": {
    "_comment": "Example MCP server configurations",
    "_filesystem": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "/path/to/allowed/directory"],
      "env": {}
    },
    "_github": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_TOKEN": "your_github_token_here"
      }
    },
    "_web": {
      "type": "sse",
      "url": "https://example-mcp-server.com/sse",
      "headers": {
        "Authorization": "Bearer YOUR_TOKEN"
      }
    }
  },
  
  "telegram": {
    "_comment": "Optional Telegram bot configuration",
    "botToken": "YOUR_BOT_TOKEN_FROM_BOTFATHER",
    "adminId": 123456789,
    "webhookUrl": "https://your-domain.com/api/telegram/webhook",
    "secretToken": "random_secret_for_webhook_validation"
  },

  "discord": {
    "_comment": "Optional Discord bot configuration. Create bot at https://discord.com/developers",
    "botToken": "YOUR_DISCORD_BOT_TOKEN",
    "allowedGuildIds": ["123456789012345678"],
    "allowedUserIds": []
  },

  "slack": {
    "_comment": "Optional Slack bot configuration. Create app at https://api.slack.com/apps",
    "_comment2": "Requires Socket Mode — generate an app-level token (xapp-...) under Basic Information",
    "botToken": "xoxb-YOUR-SLACK-BOT-TOKEN",
    "appToken": "xapp-YOUR-APP-LEVEL-TOKEN",
    "signingSecret": "YOUR_SIGNING_SECRET",
    "allowedChannelIds": [],
    "allowedUserIds": []
  },

  "workspace": {
    "_comment": "Git worktree configuration for parallel agent isolation",
    "_comment_worktreeLimit": "Max concurrent worktrees. Each uses ~200-500MB RAM. 8GB=3-4, 16GB=6-8, 32GB+=10+",
    "worktreeLimit": 4,
    "worktreeDir": ".trees",
    "copyEnvFiles": false
  }
}
