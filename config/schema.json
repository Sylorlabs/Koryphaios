{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Koryphaios App Configuration",
  "type": "object",
  "properties": {
    "app": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" },
        "identifier": { "type": "string" }
      },
      "required": ["name", "version", "identifier"]
    },
    "server": {
      "type": "object",
      "properties": {
        "host": { "type": "string" },
        "port": { "type": "number", "minimum": 1024, "maximum": 65535 },
        "wsPath": { "type": "string" }
      },
      "required": ["host", "port"]
    },
    "window": {
      "type": "object",
      "properties": {
        "width": { "type": "number", "minimum": 400 },
        "height": { "type": "number", "minimum": 300 },
        "minWidth": { "type": "number", "minimum": 400 },
        "minHeight": { "type": "number", "minimum": 300 },
        "maxWidth": { "type": "number" },
        "maxHeight": { "type": "number" }
      }
    },
    "security": {
      "type": "object",
      "properties": {
        "csp": { "type": "object" }
      }
    }
  }
}
