{
  "name": "koryphaios",
  "version": "0.1.0",
  "private": true,
  "workspaces": ["backend", "frontend", "shared", "desktop"],
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "dev:web": "bun run scripts/dev-web.ts",
    "dev:desktop": "bun run scripts/dev-desktop.ts",
    "dev:backend": "bun run --filter backend dev",
    "dev:frontend": "bun run --filter frontend dev",
    "build": "bun run --filter '*' build",
    "build:desktop": "bun run scripts/build-desktop.ts",
    "build:desktop:windows": "scripts/build-desktop-windows.bat",
    "build:desktop:macos": "scripts/build-desktop-macos.sh",
    "build:desktop:linux": "scripts/build-desktop-linux.sh",
    "build:desktop:all": "bun run scripts/build-desktop-all.ts",
    "typecheck": "bun run --filter '*' typecheck",
    "check": "bun run --filter backend typecheck && bun run --filter frontend check:strict",
    "test": "bun run --filter backend test",
    "test:all": "bun run --filter backend test:all",
    "eval": "bun run scripts/run-eval.ts",
    "diagnose": "bun run scripts/diagnose-500.ts"
  }
}
