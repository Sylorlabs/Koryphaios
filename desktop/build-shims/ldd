#!/bin/bash
# ldd shim for AppImage bundling: bun-compiled sidecars make real ldd exit 1
# with no output, which aborts linuxdeploy. They are self-contained, so an
# empty dependency list is the correct answer. Real binaries pass through.
out=$(/usr/bin/ldd "$@" 2>&1)
status=$?
echo "$out"
if [ $status -ne 0 ] && [ -z "$out" ]; then
  exit 0
fi
exit $status
